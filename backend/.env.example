# Database Connection String for Prisma pooled connections
DATABASE_URL="postgresql://username:password@supabase-connection-pooler-url:5432/postgres?pgbouncer=true&connection_limit=10"

# Direct Database Connection String for migrations
DIRECT_URL="postgresql://username:password@supabase-db-direct-host:5432/postgres"

# JWT Authentication Configuration
JWT_ACCESS_SECRET="replace-with-a-strong-random-secret-key-at-least-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"

# Application Settings
PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
